rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper functions
    // -----------------------------------------------------------------------

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------------
    // users/{userId}
    // -----------------------------------------------------------------------
    match /users/{userId} {
      // Anyone (even unauthenticated) can read profiles — public directory
      allow read: if true;
      // Only the owner can create or update their own profile
      allow create: if isOwner(userId);
      // Owner can update their profile but cannot change protected fields (tier, createdAt, role)
      // Any authenticated user can increment/decrement followerCount (follow/unfollow)
      allow update: if (isOwner(userId)
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['tier', 'createdAt', 'role']))
                    || (isAuth() && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['followerCount']));
      // Only the owner can delete their own profile (account deletion)
      allow delete: if isOwner(userId);

      // followers sub-collection — users/{userId}/followers/{followerId}
      match /followers/{followerId} {
        allow read: if true;
        allow write: if isOwner(followerId);
      }

      // following sub-collection — users/{userId}/following/{followingId}
      match /following/{followingId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // aiUsage sub-collection — users/{userId}/aiUsage/{dateKey}
      // Stores daily AI request counts; only the owner may read or write
      match /aiUsage/{dateKey} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // aiRefineUsage sub-collection — users/{userId}/aiRefineUsage/{monthKey}
      // Stores monthly AI refine counts; only the owner may read or write
      match /aiRefineUsage/{monthKey} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // -----------------------------------------------------------------------
    // posts/{postId}
    // -----------------------------------------------------------------------
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth()
                    && (
                      // Author can edit their own post
                      resource.data.authorId == request.auth.uid
                      // Any authenticated user can update like/comment counts
                      || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['likesCount', 'commentsCount', 'updatedAt'])
                    );
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

      // likes sub-collection — posts/{postId}/likes/{userId}
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // comments sub-collection — posts/{postId}/comments/{commentId}
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
                      && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth()
                      && (
                        (resource.data.authorId == request.auth.uid
                         && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['content', 'editedAt']))
                        || request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['likesCount'])
                      );
        allow delete: if isAuth()
                      && resource.data.authorId == request.auth.uid;

        // comment likes — posts/{postId}/comments/{commentId}/likes/{userId}
        match /likes/{userId} {
          allow read: if true;
          allow write: if isOwner(userId);
        }
      }
    }

    // -----------------------------------------------------------------------
    // resources/{resourceId}
    // -----------------------------------------------------------------------
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth()
                    && (
                      resource.data.authorId == request.auth.uid
                      || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['downloadCount', 'saveCount', 'ratingCount',
                                     'ratingTotal', 'updatedAt'])
                    );
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

      // ratings sub-collection — resources/{resourceId}/ratings/{userId}
      match /ratings/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // saves sub-collection — resources/{resourceId}/saves/{userId}
      match /saves/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // comments sub-collection — resources/{resourceId}/comments/{commentId}
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
                      && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth()
                      && resource.data.authorId == request.auth.uid
                      && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['content', 'editedAt']);
        allow delete: if isAuth()
                      && resource.data.authorId == request.auth.uid;
      }
    }

    // -----------------------------------------------------------------------
    // lessons/{lessonId}
    // -----------------------------------------------------------------------
    match /lessons/{lessonId} {
      // Allow all reads — Firestore cannot combine an inequality (prefix-range
      // title search) with an equality filter (isPublic) in the same query.
      // Draft privacy is enforced in the app: drafts are never linked or
      // listed outside the author's own lesson builder view.
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth()
                    && (
                      resource.data.authorId == request.auth.uid
                      || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['downloadCount', 'bookmarkCount', 'ratingAverage',
                                     'ratingCount', 'updatedAt'])
                    );
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

      // downloads sub-collection — lessons/{lessonId}/downloads/{userId}
      match /downloads/{userId} {
        allow read: if isAuth() && resource.data.authorId == request.auth.uid;
        allow write: if isOwner(userId);
      }

      // comments sub-collection — lessons/{lessonId}/comments/{commentId}
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
                      && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth()
                      && resource.data.authorId == request.auth.uid
                      && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['content', 'editedAt']);
        allow delete: if isAuth()
                      && resource.data.authorId == request.auth.uid;
      }
    }

    // -----------------------------------------------------------------------
    // forums/{categoryId}  +  forums/{categoryId}/threads/{threadId}
    // -----------------------------------------------------------------------
    match /forums/{categoryId} {
      allow read: if true;
      // Category docs are managed by the app (ensureCategory helper) — any
      // authenticated user can trigger the upsert.
      allow create, update: if isAuth();
      allow delete: if false;

      match /threads/{threadId} {
        allow read: if true;
        allow create: if isAuth()
                      && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth()
                      && (
                        resource.data.authorId == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['upvotes', 'downvotes', 'commentCount',
                                       'updatedAt'])
                      );
        allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

        // comments — forums/{categoryId}/threads/{threadId}/comments/{commentId}
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isAuth()
                        && request.resource.data.authorId == request.auth.uid;
          allow update: if isAuth()
                        && (
                          (resource.data.authorId == request.auth.uid
                           && request.resource.data.diff(resource.data)
                                .affectedKeys().hasOnly(['content', 'editedAt']))
                          || request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['upvotes', 'downvotes'])
                        );
          allow delete: if isAuth() && resource.data.authorId == request.auth.uid;
        }
      }
    }

    // -----------------------------------------------------------------------
    // collectionGroup("threads") — required for cross-category search queries
    // -----------------------------------------------------------------------
    match /{path=**}/threads/{threadId} {
      allow read: if true;
    }

    // -----------------------------------------------------------------------
    // inspiration/{itemId}
    // -----------------------------------------------------------------------
    match /inspiration/{itemId} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.submittedBy == request.auth.uid;
      allow update, delete: if isAuth()
                            && resource.data.submittedBy == request.auth.uid;
    }

    // -----------------------------------------------------------------------
    // jobs/{jobId}
    // -----------------------------------------------------------------------
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuth()
                    && (
                      request.resource.data.postedBy == request.auth.uid
                      || request.resource.data.postedById == request.auth.uid
                    );
      allow update, delete: if isAuth()
                            && (
                              resource.data.postedBy == request.auth.uid
                              || resource.data.postedById == request.auth.uid
                            );
    }

    // -----------------------------------------------------------------------
    // notifications/{userId}/items/{notificationId}
    // -----------------------------------------------------------------------
    match /notifications/{userId}/items/{notificationId} {
      // Only the recipient can read their own notifications
      allow read: if isOwner(userId);
      // Any authenticated user can create a notification for another user,
      // but the actorId must match the authenticated user (prevents impersonation).
      // System/badge notifications use actorId == "system" — also permitted.
      allow create: if isAuth()
                    && (request.resource.data.actorId == request.auth.uid
                        || request.resource.data.actorId == "system"
                        || isOwner(userId));
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // -----------------------------------------------------------------------
    // bookmarks/{bookmarkId}  (bookmarkId = "{userId}_{lessonId}")
    // -----------------------------------------------------------------------
    match /bookmarks/{bookmarkId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuth()
                    && request.auth.uid == resource.data.userId;
    }

    // -----------------------------------------------------------------------
    // ratings/{ratingId}  (ratingId = "{userId}_{lessonId}")
    // -----------------------------------------------------------------------
    match /ratings/{ratingId} {
      // Any authenticated user can read (needed for aggregate recalculation query)
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.userId;
      allow update: if isAuth()
                    && request.auth.uid == resource.data.userId;
    }

    // -----------------------------------------------------------------------
    // follows/{followId}  (followId = "{followerId}_{followeeId}")
    // Top-level follow documents used for defensive access control.
    // The primary follow data lives in users/{uid}/followers and /following
    // sub-collections (see rules above), but this rule covers any top-level
    // follows collection that may be written to in future.
    // -----------------------------------------------------------------------
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.followerId;
      allow update: if false;
      allow delete: if isAuth()
                    && request.auth.uid == resource.data.followerId;
    }

    // -----------------------------------------------------------------------
    // Deny everything else
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
