{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "plugins": [],
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "types/next-env.typecheck.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "scripts/**/*.mts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "next.config.ts",
    "proxy.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
